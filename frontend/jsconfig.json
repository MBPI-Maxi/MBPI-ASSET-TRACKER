{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@constants/*": ["constants/*"], 
      "@context/*": ["context/*"],
      "@layout/*": ["layout/*"],
      "@pages/*": ["pages/*"],
      "@provider/*": ["provider/*"],
      "@api/*": ["api/*"]
    }
  },
  "include": ["src"]
}
